    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const body = $input.first().json.body || {};\n\nconst firstName    = (body.firstName || '').trim();\nconst lastName     = (body.lastName  || '').trim();\nconst email        = (body.email     || '').trim();\nconst company      = (body.company   || '').trim();\nconst service      = (body.service   || '').trim();\nconst fullName     = (firstName + ' ' + lastName).trim();\n\nconst now          = new Date();\nconst pad          = n => String(n).padStart(2, '0');\nconst timestamp    = now.getFullYear() + '-' + pad(now.getMonth()+1) + '-' + pad(now.getDate()) + ' ' + pad(now.getHours()) + ':' + pad(now.getMinutes()) + ':' + pad(now.getSeconds());\nconst submissionId = Date.now() + '-' + Math.random().toString(36).substring(2, 8);\n\nconst emailValid = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]{2,}$/.test(email);\n\nreturn [{\n  json: {\n    firstName, lastName, fullName, email, company, service,\n    timestamp, submissionId,\n    status:        emailValid ? 'Pending' : 'Failed',\n    failureReason: emailValid ? ''        : 'Invalid email address format',\n    emailValid\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
