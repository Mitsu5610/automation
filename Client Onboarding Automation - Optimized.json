    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const data   = $input.first().json;\nconst domain = data.email.split('@')[1];\n\ntry {\n  const res    = await fetch('https://dns.google/resolve?name=' + encodeURIComponent(domain) + '&type=MX');\n  const result = await res.json();\n\n  if (result.Status === 0 && Array.isArray(result.Answer) && result.Answer.length > 0) {\n    return [{ json: { ...data, mxValid: true } }];\n  }\n\n  return [{ json: { ...data, mxValid: false, status: 'Failed', failureReason: 'Email domain has no valid mail server (MX record) — address likely does not exist' } }];\n\n} catch (err) {\n  return [{ json: { ...data, mxValid: false, status: 'Failed', failureReason: err.message || 'Could not verify email domain (DNS lookup failed)' } }];\n}"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-9968, 11664],
